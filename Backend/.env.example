# Server Configuration
PORT=5000
NODE_ENV=development

# Database
# For local MongoDB: mongodb://localhost:27017/worknet
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGO_URI=mongodb://localhost:27017/worknet

# JWT Authentication
JWT_SECRET=your_random_secret_string

# Frontend URL (for CORS and email links)
CLIENT_URL=http://localhost:5173

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Configuration (SMTP)
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SENDER_NAME=Worknet
SENDER_EMAIL=your_email@gmail.com

# AI Configuration (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Job scheduler (Optional)
JOB_ROW_CRON=0 8,16 * * *
JOB_ROW_CRON_TZ=Asia/Kolkata
