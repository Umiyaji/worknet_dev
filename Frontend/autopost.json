      "id": "if-unprocessed",
      "name": "If Unprocessed",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        460,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const row = $input.first().json;\n\nconst clean = (v) => String(v ?? '').trim();\n\nconst skillsArray = clean(row.skillsRequired)\n  .split(',')\n  .map(skill => skill.trim())\n  .filter(Boolean);\n\nreturn [\n  {\n    json: {\n      rowNumber: row.rowNumber || row.Row || row['Row Number'] || row.row || '',\n      companyUsername: clean(row.companyUsername).toLowerCase(),\n      companyName: clean(row.companyName),\n      role: clean(row.role),\n      totalOpenings: Number(row.totalOpenings || 0),\n      experienceRequired: clean(row.experienceRequired),\n      workMode: clean(row.workMode),\n      officeLocation: clean(row.officeLocation),\n      skillsRequired: skillsArray,\n      skillsRequiredText: skillsArray.join(', '),\n      lastDateToApply: clean(row.lastDateToApply),\n      source: 'google-sheet-gemini',\n      sourceRowId: clean(row.sourceRowId || row.rowNumber || row.Row || Date.now()),\n      originalRow: row\n    }\n  }\n];"
      },
      "id": "code-normalize",
      "name": "Normalize Row",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        300
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Write a professional hiring post for a company social platform.\n\nUse only the facts below.\n\nCompany: {{$json.companyName}}\nRole: {{$json.role}}\nOpenings: {{$json.totalOpenings}}\nExperience Required: {{$json.experienceRequired}}\nWork Mode: {{$json.workMode}}\nOffice Location: {{$json.officeLocation}}\nSkills Required: {{$json.skillsRequiredText}}\nLast Date to Apply: {{$json.lastDateToApply}}\n\nRules:\n- Do not invent any facts\n- Do not add salary, benefits, perks, or company culture\n- Do not change numbers, names, skills, or dates\n- Keep it concise and professional\n- Write as if posted by the company account\n- Output only the final post text\n- Keep it under 120 words",
        "messages": {
          "messageValues": []
        }
      },
      "id": "gemini-prompt",
      "name": "Generate Post With Gemini",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.6,
      "position": [
        960,
        300
      ]
    },
    {
